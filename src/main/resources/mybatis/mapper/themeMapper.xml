<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.noexit.app.mapper.ThemeMapper">

<!-- 
		List<GenreDTO> getGenreList();
		List<Cafe> getCafeList(long userId);
		int themeInsert(ThemeDTO dto);
		int themeUpdate(ThemeDTO dto);
		int themeDelete(long themeId);
		
		
		
		ThemeDTO getThemeById(long themeId);
		List<ThemeDTO> getThemeList(Map<String, Object> map);
		List<ThemeSlotDTO> getThemeSlot(long themeId);
		List<ThemeReviewDTO> getThemeReview(long themeId);
 -->
 	
    <!-- 테마등록  -->
 	<insert id="themeInsert" parameterType="com.noexit.app.model.ThemeDTO">
 		<selectKey keyProperty="themeId" resultType="long" order="BEFORE">
 			SELECT ROOM_SEQ.NEXTVAL FROM DUAL
 		</selectKey>
 		INSERT INTO ROOM (
 			ROOM_ID, CAFE_ID, ROOM_NAME, GENRE_ID, DURATION,
 			DIFFICULTY, HORROR_GRADE, ACTIVITY_GRADE,
 			MIN_PLAYERS, MAX_PLAYERS, ROOM_DESC, ROOM_IMG, PRICE, IS_ADULT
 		) VALUES (
 			#{themeId}, #{cafeId}, #{themeName}, #{genre}, #{duration},
 			#{difficulty}, #{horror}, #{activity},
 			#{minPlayers}, #{maxPlayers}, #{description}, #{imagePath}, #{price}, #{adult}
 		)
 	</insert>

 	<!-- 테마 단일 조회 (수정 폼용) -->
 	<select id="getThemeById" parameterType="long" resultType="com.noexit.app.model.ThemeDTO">
 		SELECT ROOM_ID themeId, ROOM_IMG imagePath, CAFE_ID cafeId,
 		       ROOM_NAME themeName, GENRE_ID genre, DURATION duration,
 		       DIFFICULTY difficulty, HORROR_GRADE horror, ACTIVITY_GRADE activity,
 		       PRICE price, IS_ADULT adult, MIN_PLAYERS minPlayers,
 		       MAX_PLAYERS maxPlayers, ROOM_DESC description
 		  FROM ROOM
 		 WHERE ROOM_ID = #{themeId}
 	</select>

 	<!-- 본인 카페의 테마 리스트 (사장 수정 메뉴용) -->
 	<select id="selectListByOwnerUserId" parameterType="long" resultType="com.noexit.app.model.ThemeDTO">
 		SELECT R.ROOM_ID themeId, R.ROOM_NAME themeName, R.ROOM_IMG imagePath,
 		       C.CAFE_ID cafeId, C.CAFE_NAME cafeName,
 		       G.GENRE_NAME genre,
 		       R.PRICE price, R.MAX_PLAYERS maxPlayers
 		  FROM ROOM R
 		  JOIN CAFE       C ON R.CAFE_ID  = C.CAFE_ID
 		  JOIN ROOM_GENRE G ON R.GENRE_ID = G.GENRE_ID
 		 WHERE C.USER_ID = #{ownerUserId}
 		 ORDER BY R.ROOM_ID DESC
 	</select>

 	<!-- 테마 수정 -->
 	<update id="themeUpdate" parameterType="com.noexit.app.model.ThemeDTO">
 		UPDATE ROOM
 		   SET CAFE_ID         = #{cafeId},
 		       ROOM_NAME       = #{themeName},
 		       GENRE_ID        = #{genre},
 		       DURATION        = #{duration},
 		       DIFFICULTY      = #{difficulty},
 		       HORROR_GRADE    = #{horror},
 		       ACTIVITY_GRADE  = #{activity},
 		       MIN_PLAYERS     = #{minPlayers},
 		       MAX_PLAYERS     = #{maxPlayers},
 		       ROOM_DESC       = #{description},
 		       ROOM_IMG        = #{imagePath},
 		       PRICE           = #{price},
 		       IS_ADULT        = #{adult}
 		 WHERE ROOM_ID = #{themeId}
 	</update>


 	<sql id="where-list">
 		<![CDATA[
			(INSTR(${schType},#{kwd}) > 0) 			
 		]]>		 		
 	</sql>
 	
 	
 	<!--
 	테마 정보 가져오기
 	<select id="getThemeById" parameterType="long" resultType="com.noexit.app.model.ThemeDTO">
		SELECT A.ROOM_ID themeId, A.ROOM_IMG imagePath, B.CAFE_NAME cafeName
		, B.ADDRESS || ' ' || B.ADDRESS_DETAIL cafeLocation, B.PHONE cafePhone
