<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.noexit.app.mapper.CommonMapper">

	<select id="getCommonList" resultType="com.noexit.app.model.Common">
		SELECT COMMON_ID, COMMON_NAME
		FROM COMMON
		ORDER BY COMMON_ID
	</select>

</mapper>
